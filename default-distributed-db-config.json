{
  "autoDeploy": true,
  "hotAlignment": true,
  "readQuorum": 1,
  "writeQuorum": 2,
  "readYourWrites": true,
  "failureStrategy": "sharding",
  "servers": {
    "*": "master"
  },
  "clusters": {
    "internal": {
      "servers": ["<ALL>"]
    },
    "*": {
      "servers": ["<ALL>"]
    }
  }
}